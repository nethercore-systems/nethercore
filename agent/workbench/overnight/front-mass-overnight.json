{
  "manifest_version": 1,
  "kind": "epu_workbench_batch",
  "name": "front-mass-overnight",
  "lane": "Front Mass",
  "target": {
    "mode": "benchmark",
    "scene_index": 4,
    "scene_name": "Front Mass"
  },
  "artifacts_dir_hint": "tmp/epu-workbench-live",
  "description": "Small overnight discovery batch for the blocked Front Mass lane. Every candidate resets the live benchmark scene, restores the review view, captures the triplet, and exports the patched config.",
  "review_focus": [
    "stronger scene-owning wall/front body in direct background",
    "probe read should stop collapsing into a generic hemispheric split",
    "support motion should stay visible without replacing MASS as the primary carrier"
  ],
  "candidates": [
    {
      "id": "baseline-current",
      "hypothesis": "Capture the current authored Front Mass baseline before testing new support/body balance.",
      "steps": [
        {
          "action": "select-scene",
          "mode": "benchmark",
          "scene_index": 4,
          "load_into_editor": true,
          "lock_editor": true
        },
        {
          "action": "set-view",
          "view": {
            "locked": true,
            "show_benchmarks": true,
            "scene_index": 4,
            "show_ui": false,
            "show_probe": true,
            "show_background": true,
            "clear_layer_isolation": true
          }
        },
        {
          "action": "capture",
          "label": "front-mass-baseline-current"
        },
        {
          "action": "export",
          "label": "front-mass-baseline-current",
          "rust_const_name": "BENCHMARK_FRONT_MASS_BASELINE_CURRENT",
          "include_json_text": true,
          "include_rust_text": true
        }
      ]
    },
    {
